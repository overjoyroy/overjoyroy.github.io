// Firestore Security Rules
// Deploy these in the Firebase Console → Firestore → Rules tab
// (or via Firebase CLI: firebase deploy --only firestore:rules)

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // User profile: owner reads/writes; any authenticated user can read
    // (needed for the friends tab to load friend profiles)
    match /users/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Card collection: any authenticated user can read (for friends view)
    // Only the owner can write their own collection
    match /collections/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }

    // Want lists: same pattern as collections
    match /wantlists/{uid} {
      allow read:  if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
